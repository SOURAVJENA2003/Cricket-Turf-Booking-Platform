# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Absolute connection URL for the PostgreSQL instance (compatible with Neon pools)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# -----------------------------------------------------------------------------
# Admin Authentication
# -----------------------------------------------------------------------------
# Email address for the administrator dashboard account
ADMIN_EMAIL=admin@cricketturf.com
# Bcrypt hash of the admin password. Generate using a bcrypt helper tool.
# Placeholder below corresponds to password: "adminPassword123"
ADMIN_PASSWORD_HASH=$2a$10$9F7.gC25p7p.16t3P.oJ0eM1HjL1d3c52e4e6g8i0k2m4o6q8s0u2
# Strong secret key for signing admin session tokens (min 32 characters recommended)
JWT_SECRET=your_jwt_session_signing_secret_key_here_32_chars_long

# -----------------------------------------------------------------------------
# Payments Configuration
# -----------------------------------------------------------------------------
# Selected payment mode: "upi" (Manual QR scan & UTR) or "razorpay" (Online Sandbox Checkout)
PAYMENT_MODE=upi

# UPI settings (required if PAYMENT_MODE=upi)
UPI_ID=yourname@upi
UPI_NAME=Your Full Name

# Razorpay Test Credentials (required if PAYMENT_MODE=razorpay)
RAZORPAY_KEY_ID=rzp_test_yourKeyIdHere
RAZORPAY_KEY_SECRET=yourKeySecretHere

# -----------------------------------------------------------------------------
# Turf Configuration
# -----------------------------------------------------------------------------
# Display title of the turf arena
TURF_NAME=Runmakers Arena Box Cricket
# Physical address of the venue
TURF_ADDRESS=Infront of Omfed Plant, Railway Station Rd, Chowk, Bankobija, Jeypore, Odisha 764002
# Google Maps sharable link or search URL
TURF_GOOGLE_MAPS=https://www.google.com/maps/place/Runmakers+Arena+Box+Cricket/data=!4m2!3m1!1s0x0:0x453d498e3c55270?sa=X&ved=1t:2428&hl=en-IN&ictx=111
# Operating opening hours in HH:MM format
TURF_OPEN_TIME=06:00
# Operating closing hours in HH:MM format
TURF_CLOSE_TIME=23:00

# -----------------------------------------------------------------------------
# Pricing Configuration
# -----------------------------------------------------------------------------
# Standard default price per hourly turf booking slot (e.g. 1000.00 INR)
DEFAULT_SLOT_PRICE=1000.00

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# Application node runtime environment
NODE_ENV=development
# Port number the server binds to
PORT=3000
